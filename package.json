{
  "name": "vite-plugin-vercel-workspace-root",
  "packageManager": "pnpm@10.24.0",
  "private": "true",
  "type": "module",
  "scripts": {
    "dev": "pnpm run -C ./packages/vercel dev",
    "build": "pnpm --recursive run build",
    "test:e2e": "pnpm --recursive run --workspace-concurrency 1 test:e2e",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "publish:beta": "changeset pre enter beta && changeset version && pnpm publish -r --no-git-checks --tag beta",
    "publish:stable": "changeset version && changeset publish -r"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0",
    "playwright": "^1.57.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@>=4.0.0 <6.3.0": "^6.3.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
